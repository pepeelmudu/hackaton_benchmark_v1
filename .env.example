# Copia este archivo a .env.local y rellena los valores.

# Requerida (al menos una): clave de la API de Anthropic (para el análisis con Claude).
# Si está presente, tiene PRIORIDAD sobre xAI.
ANTHROPIC_API_KEY=

# Alternativa: clave de la API de xAI (Grok). Se usa solo si ANTHROPIC_API_KEY está vacía.
# xAI es compatible con el SDK de Anthropic (baseURL https://api.x.ai).
XAI_API_KEY=
# Opcional: modelo de xAI a usar (por defecto: grok-4)
XAI_MODEL=

# Opcional: token de GitHub para clonar repos privados sin `gh`.
# Si usas `gh auth login`, no hace falta. Si no, crea un PAT con scope `repo`.
GITHUB_TOKEN=
