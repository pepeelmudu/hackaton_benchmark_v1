# Copia este archivo a .env.local y rellena los valores.

# Requerida: clave de la API de Anthropic (para el análisis con Claude)
ANTHROPIC_API_KEY=

# Opcional: token de GitHub para clonar repos privados sin `gh`.
# Si usas `gh auth login`, no hace falta. Si no, crea un PAT con scope `repo`.
GITHUB_TOKEN=
